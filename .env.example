# ─── API ──────────────────────────────────────────────────────────────────────
# Always use the relative path. In dev Vite proxies /api/* to localhost:3000;
# in production vercel.json rewrites /api/* to the Railway backend.
# This keeps auth cookies same-origin in both environments.
VITE_API_URL=/api

# ─── Supabase (Realtime broadcast subscriptions) ─────────────────────────────
# Used ONLY by the support chat inbox to subscribe to channel
# `chat:{conversationId}` for live message delivery. The anon key is safe
# to expose (it's the public-website key); we never read DB rows from the
# browser — sensitive data flows through the authenticated backend API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
